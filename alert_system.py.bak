"""
alert_system.py
───────────────
Handles unknown-face alerts:
  - Email with snapshot attachment (via Gmail SMTP)
  - Console / log alerts
  - Cooldown to avoid alert spam
"""

import os
import smtplib
import sqlite3
import time
from email.mime.multipart import MIMEMultipart
from email.mime.text      import MIMEText
from email.mime.image     import MIMEImage
from datetime             import datetime
from dotenv               import load_dotenv
import urllib.request
import json

load_dotenv()

# --- Geolocation (IP-based) ---
def get_location():
    try:
        url = "http://ip-api.com/json/?fields=city,regionName,country,lat,lon,status"
        with urllib.request.urlopen(url, timeout=5) as r:
            data = json.loads(r.read().decode())
        if data.get("status") == "success":
            return data
    except Exception:
        pass
    return {}


# ─── Config (set these in .env) ───────────────────────────────────────────────
SENDER_EMAIL    = os.getenv("ALERT_EMAIL_FROM",     "")
SENDER_PASSWORD = os.getenv("ALERT_EMAIL_PASSWORD", "")   # use App Password for Gmail
RECEIVER_EMAIL  = os.getenv("ALERT_EMAIL_TO",       "")
SMTP_HOST       = os.getenv("SMTP_HOST", "smtp.gmail.com")
SMTP_PORT       = int(os.getenv("SMTP_PORT", "587"))

DB_PATH         = "database/faces.db"

# Cooldown: send at most 1 alert every N seconds (prevents spam)
ALERT_COOLDOWN  = 30   # seconds
_last_alert_time: float = 0.0


# ─── Email Alert ──────────────────────────────────────────────────────────────
def send_email_alert(snapshot_path: str) -> bool:
    """
    Send an email with the unknown-face snapshot attached.
    Returns True if sent successfully.
    """
    if not all([SENDER_EMAIL, SENDER_PASSWORD, RECEIVER_EMAIL]):
        print("[AlertSystem] Email not configured — skipping email alert.")
        return False

    try:
        msg = MIMEMultipart()
        msg["From"]    = SENDER_EMAIL
        msg["To"]      = RECEIVER_EMAIL
        msg["Subject"] = f"⚠️ Face Recognition Alert — Unknown Person Detected"

        ts   = datetime.now().strftime("%B %d, %Y at %I:%M:%S %p")
        _loc = get_location()
        loc_str = f"{_loc.get('city','Unknown')}, {_loc.get('regionName','')}, {_loc.get('country','')}" if _loc else "Location unavailable"
        maps_url = f"https://maps.google.com/?q={_loc['lat']},{_loc['lon']}" if _loc else "#"
        body = f"""
        <html><body style="font-family: Arial, sans-serif; background:#f4f4f4; padding:20px">
          <div style="background:white; border-radius:10px; padding:24px; max-width:500px; margin:auto">
            <h2 style="color:#e74c3c">⚠️ Unknown Person Detected</h2>
            <p>An unrecognised face was detected by your Face Recognition System.</p>
            <table style="width:100%; border-collapse:collapse; margin:16px 0">
              <tr><td style="padding:8px; color:#777">Time</td><td style="padding:8px"><b>{ts}</b></td></tr>
              <tr><td style="padding:8px; color:#777">Status</td><td style="padding:8px"><b style="color:#e74c3c">NOT in database</b></td></tr>
              <tr><td style="padding:8px; color:#777">Location</td><td style="padding:8px"><b>{loc_str}</b></td></tr>
              <tr><td style="padding:8px; color:#777">Maps</td><td style="padding:8px"><a href="{maps_url}">Open in Google Maps</a></td></tr>
            </table>
            <p>Please check the attached snapshot.</p>
            <hr style="border:none; border-top:1px solid #eee; margin:20px 0"/>
            <p style="color:#aaa; font-size:12px">Sent by Smart Face Recognition System</p>
          </div>
        </body></html>
        """
        msg.attach(MIMEText(body, "html"))

        # Attach snapshot image
        if os.path.exists(snapshot_path):
            with open(snapshot_path, "rb") as f:
                img = MIMEImage(f.read(), name=os.path.basename(snapshot_path))
                msg.attach(img)

        with smtplib.SMTP(SMTP_HOST, SMTP_PORT) as server:
            server.ehlo()
            server.starttls()
            server.login(SENDER_EMAIL, SENDER_PASSWORD)
            server.sendmail(SENDER_EMAIL, RECEIVER_EMAIL, msg.as_string())

        # Mark as sent in DB
        _mark_alert_sent(snapshot_path)
        print(f"[AlertSystem] ✅ Email alert sent to {RECEIVER_EMAIL}")
        return True

    except Exception as e:
        print(f"[AlertSystem] ❌ Email failed: {e}")
        return False


def _mark_alert_sent(snapshot_path: str):
    conn = sqlite3.connect(DB_PATH)
    c    = conn.cursor()
    c.execute("UPDATE alerts SET email_sent = 1 WHERE snapshot = ?", (snapshot_path,))
    conn.commit()
    conn.close()


# ─── Trigger Alert (with cooldown) ────────────────────────────────────────────
def trigger_alert(snapshot_path: str, send_email: bool = True) -> bool:
    """
    Called whenever an unknown face is detected.
    Respects cooldown so you don't get spammed every frame.
    """
    global _last_alert_time
    now = time.time()

    if now - _last_alert_time < ALERT_COOLDOWN:
        return False   # still in cooldown

    _last_alert_time = now
    print(f"[AlertSystem] 🚨 Unknown face alert triggered!")

    if send_email:
        send_email_alert(snapshot_path)

    return True


# ─── .env Template ────────────────────────────────────────────────────────────
def create_env_template():
    template = """\
# ─── Email Alert Configuration ────────────────────────────────────────────────
# Use a Gmail App Password (not your main password)
# Generate at: https://myaccount.google.com/apppasswords

ALERT_EMAIL_FROM=your_email@gmail.com
ALERT_EMAIL_PASSWORD=your_app_password_here
ALERT_EMAIL_TO=receiver_email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
"""
    if not os.path.exists(".env"):
        with open(".env", "w") as f:
            f.write(template)
        print("[AlertSystem] .env template created — fill in your email credentials.")
